APP_ENV=production
HTTP_ADDR=:8080
FRONTEND_URL=https://your-frontend-domain.com
DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_MAX_CONNS=20
JWT_ACCESS_SECRET=replace-with-32-byte-access-secret
JWT_REFRESH_SECRET=replace-with-32-byte-refresh-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://your-api-domain.com/api/auth/google/callback
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
COOKIE_SECURE=true
