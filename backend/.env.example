APP_ENV=development
HTTP_ADDR=:8080
FRONTEND_URL=http://localhost:3000

# PostgreSQL / Neon
DATABASE_URL=postgres://ikisha:ikisha@postgres:5432/ikisha?sslmode=disable
DATABASE_MAX_CONNS=20

# JWT secrets must be unique random values with at least 32 characters in production.
# Do not commit real secrets. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=dnXRjXOxbTPIm6ko6KwEc4/kmQMbv6o24hWw9k5xPy0s8hJIZdC7tosjRBKn1vJ/
JWT_REFRESH_SECRET=dnXRjXOxbTPIm6ko6KwEc4/kmQMbv6o24hWw9k5xPy0s8hJIZdC7tosjRBKn1vJ/
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720

# Google OAuth is the only authentication provider.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Cloudinary handles image optimization and CDN delivery.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_UPLOAD_FOLDER=ikisha/dev
CLOUDINARY_ALLOWED_FORMATS=jpg,jpeg,png,webp,avif
CLOUDINARY_MAX_IMAGE_BYTES=25000000

# Mux handles video upload, transcoding, HLS playback, and thumbnails.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# Cookies are HTTP-only. Keep COOKIE_SECURE=true outside local HTTP development.
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAME_SITE=Lax

# Optional Redis for queues, rate limits, cache coordination, and analytics buffers.
REDIS_URL=redis://redis:6379/0

# Public routing and publishing.
PUBLIC_ROOT_DOMAIN=ikisha.studio
PUBLIC_BASE_URL=http://localhost:3000
PUBLISH_REVALIDATE_SECRET=replace-with-random-revalidation-secret
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Observability.
LOG_LEVEL=debug
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
