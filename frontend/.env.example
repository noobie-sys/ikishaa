NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
INTERNAL_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Server-only secret used by the backend publish job to trigger ISR revalidation later.
PUBLISH_REVALIDATE_SECRET=replace-with-same-value-as-backend

# Cloudinary delivery config for image URL generation in template renderers.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_SECURE_DISTRIBUTION=

# Mux playback config for public video players.
NEXT_PUBLIC_MUX_ENV_KEY=
